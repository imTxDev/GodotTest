[sub_resource type="GDScript" id="GDScript_4dvvg"]
resource_name = "Test"
script/source = "extends Node2D

@export var button: Button
@export var health: Health
@export var progress_bar: ProgressBar
func _ready() -> void:
	button.pressed.connect(health.on_took_damage.bind(10))
	progress_bar.max_value = health.max_health
	progress_bar.value = health.max_health
	health.health_changed.connect(update_progress_bar)

func update_progress_bar() -> void:
	progress_bar.value = health.current_health
"

