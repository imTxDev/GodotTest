[sub_resource type="GDScript" id="GDScript_4dvvg"]
resource_name = "Test"
script/source = "extends Node2D

@export var button: Button
@export var health: HPComponent
@export var progress_bar: ProgressBar

func _ready() -> void:
	button.pressed.connect(health.took_damage.bind(10))
	health.HP_changed.connect(update_progress_bar)
	progress_bar.max_value = health.max_HP
	progress_bar.value = health.max_HP


func update_progress_bar() -> void:
	progress_bar.value = health.current_HP
	
"

